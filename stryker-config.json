{
  "stryker-config": {
    "solution": "TaskKing.sln",
    "project": "TaskKing.Api/TaskKing.Api.csproj",
    "test-projects": [
      "TaskKing.Tests/TaskKing.Tests.csproj"
    ],
    "reporters": [
      "html",
      "progress",
      "cleartext"
    ],
    "mutate": [
      "!**/Controllers/*.cs",
      "!**/Program.cs",
      "!**/Migrations/**/*.cs",
      "!**/Models/TaskItem.cs"
    ],
    "ignore-methods": [
      "*Controller*"
    ],
    "mutation-level": "Complete"
  }
}